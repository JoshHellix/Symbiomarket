# Arc testnet (Phase 2b public settlement)
# SEND via Canteen/Agora RPC (tracks your GitHub + on-chain activity for judges):
# ARC_RPC=https://rpc.testnet.arc-node.thecanteenapp.com/v1/YOUR_SWARM_KEY
# Hard fork: arc-node v0.7.1+ — https://github.com/circlefin/arc-node/tags
ARC_RPC=https://rpc.testnet.arc-node.thecanteenapp.com/v1/YOUR_SWARM_KEY
# READ receipts via public Arc RPC (Canteen send RPC often cannot return receipts):
ARC_READ_RPC=https://rpc.testnet.arc.network
PRIVATE_KEY=your_private_key_with_arc_testnet_gas
WALLET_ADDRESS=0xYourWalletAddress

# Optional: also used for fhe-contracts Sepolia deploy
# FHE_PRIVATE_KEY=your_private_key