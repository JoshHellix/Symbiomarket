# Wallet that pays gas on Ethereum Sepolia (can reuse Arc testnet key if it has Sepolia ETH)
# With or without 0x prefix
FHE_PRIVATE_KEY=your_private_key_here

# Optional RPC override
# Try these if deploy times out: https://sepolia.drpc.org or https://1rpc.io/sepolia
# Best: Alchemy/Infura Sepolia URL (free tier)
FHEVM_SEPOLIA_RPC_URL=https://sepolia.drpc.org

# After deploy:sepolia
FHE_COUNTER_ADDRESS=0xYourDeployedCounterAddress
